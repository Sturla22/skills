{
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    ".claude/rules": true,
    "~/.copilot/instructions": false,
    "~/.claude/rules": false
  },
  "chat.includeApplyingInstructions": true,
  "chat.includeReferencedInstructions": true,
  "chat.agentFilesLocations": {
    ".github/agents": true
  },
  "github.copilot.chat.organizationInstructions.enabled": true,
  "github.copilot.chat.organizationCustomAgents.enabled": true,
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    },
    {
      "file": "AGENTS.md"
    }
  ],
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    },
    {
      "text": "Use Conventional Commit style subjects. Keep the subject short, imperative, and without a trailing period."
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    },
    {
      "text": "Summarize user-visible impact, verification, and remaining risks."
    }
  ],
  "chat.agent.maxRequests": 6
}
